<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        body{
            background-color: rgb(238, 238, 243);
            text-align: center;
            margin: 0;
        }
        .main{
            background-color: rgb(137, 137, 182);
            text-align: center;
            border-radius: 20px;
            margin: 0;
            width: 80vw;
            height: 80vh;
            position: relative;
            top: 5vh;
            left: 10vw;
        }
        .box1{
            text-align: center;
            color:rgb(231, 227, 227);
            width: 30%;
            height: 60%;
            position: absolute;
            right:5vw;
            top:15vh;
        }
        .box1 img{
            width: 100%;
            height: 100%;
        object-fit: cover;
        border-radius: 20px;
        }
        .box2{
            text-align: center;
            color:rgb(231, 227, 227);
            width: 20vw;
            height: 20vh;
            border:2px solid rgb(9, 9, 23);
            position: absolute;
            left:5vw;
            top:10vh;
            border-radius: 10px;
            
        }
        .box3{
            text-align: center;
            color:rgb(231, 227, 227);
            width: 20vw;
            height: 20vh;
            border:2px solid rgb(9, 9, 22);
            position: absolute;
            left:5vw;
            bottom:10vh;
            border-radius: 10px;
        }
        .color1{
            background-color: rgb(31, 31, 190);
            width:20vw;
            height:15vh;
          
        }
        .color2{
            background-color: rgb(194, 18, 150);
            width:20vw;
            height:15vh;
           
        }
        button{
            width:20vw;
            height:5vh;
            background-color: rgb(1, 14, 21);
            color:white;
        
            border:2px solid rgb(17, 15, 15);
            font-size: large;
        }
    </style>
</head>
<body>
    <div class="main">
         <div class="box1">
            <img src="https://www.bing.com/th/id/OIP.UCVFWOoGObol5zY5Us62mwHaLH?w=193&h=290&c=8&rs=1&qlt=90&o=6&dpr=1.3&pid=ImgAns&rm=2" alt="">
         </div>
         <div class="box2" >
             <div class="color1">
       
             </div>
          
             <button id = "p1" onclick = "changeTop()">Click Me</button>
             <br></br>
         </div>
         <div class="box3">
              <div class="color2">
                
             </div>
          
             <button id = "p2" onclick = "changeBottom()">Click Me</button>
             <br></br>
         </div>
    </div>
</body>
<script>
    let topColor = { r: 31, g: 31, b: 190 };
    let bottomColor = { r: 194, g: 18, b: 150 };

    function changeBottom() {
        bottomColor.r = (bottomColor.r + 20) % 256;
        bottomColor.g = (bottomColor.g + 15) % 256;
        bottomColor.b = (bottomColor.b + 10) % 256;
        document.getElementsByClassName('color2')[0].style.backgroundColor = `rgb(${bottomColor.r}, ${bottomColor.g}, ${bottomColor.b})`;
    }

    function changeTop() {
        topColor.r = (topColor.r + 15) % 256;
        topColor.g = (topColor.g + 20) % 256;
        topColor.b = (topColor.b + 10) % 256;
        document.getElementsByClassName('color1')[0].style.backgroundColor = `rgb(${topColor.r}, ${topColor.g}, ${topColor.b})`;
    }
</script>
</html>
