<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        #text{
            background-color: blue;
            text-align: center;
            color:white;
            

        }
        #button1{
            background-color: green;
            text-align: center;
            width:100px;
            color:white;
            border-radius: 10px;
        }
        #button2{
            background-color: red;
            text-align: center;
            width:100px;
            color:white;
            border-radius: 10px;
        }
    </style>
    <script src ="index.js"></script>
</head>
<body>
   
    <h1 id = "text">Is Javascript is easy ?</h1>
    <button id = "button1">Yes</button>
    <button id = "button2">No</button>
</body>
<script>
    document.getElementById("button1").onclick = function(){
        document.getElementById("text").innerHTML = "Yes Javascript is easy "
    }
    document.getElementById("button2").onclick = function(){
        document.getElementById("text").innerHTML = "No Javascript is Not easy "
    }
</script>
</html>


